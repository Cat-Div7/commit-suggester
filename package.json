{
  "name": "sgt-cli",
  "version": "1.0.0",
  "description": "AI-powered git commit message suggester — supports Gemini, Claude, OpenRouter, and Ollama",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "sgt": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "git",
    "commit",
    "ai",
    "cli",
    "gemini",
    "claude",
    "openrouter",
    "ollama",
    "conventional-commits"
  ],
  "author": "Omar Ashraf <github.com/Cat-Div7>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cat-Div7/commit-suggester.git"
  },
  "bugs": {
    "url": "https://github.com/Cat-Div7/commit-suggester/issues"
  },
  "homepage": "https://github.com/Cat-Div7/commit-suggester#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@types/jest": "^30.0.0",
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "conf": "^15.1.0",
    "dotenv": "^17.3.1",
    "figlet": "^1.11.0",
    "inquirer": "^8.2.7",
    "jest": "^30.3.0",
    "ora": "^9.3.0",
    "simple-git": "^3.33.0",
    "ts-jest": "^29.4.6"
  },
  "devDependencies": {
    "@types/figlet": "^1.5.8",
    "@types/inquirer": "^8.2.12",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
